// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// model Group
// Implicit many-to-many relation till User via tabellen _UserGroups
model Group {
  id        String   @id @default(cuid())
  name      String   @unique // Gjort unik för att underlätta "join by name"
  users     User[]   @relation("UserGroups")
  createdAt DateTime @default(now())
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  name          String
  role          Role      @default(USER)

  // Många-till-många relation till grupper
  groups        Group[]   @relation("UserGroups")

  todos         Todo[]
  postIts       PostIt[]
  createdAt     DateTime  @default(now())
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  ADMIN
  GUEST
}

enum RecurrenceType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

model Todo {
  id              String         @id @default(cuid())
  title           String
  date            String         // Startdatum (YYYY-MM-DD)
  time            String?        // Starttid (HH:mm)
  endTime         String?        // Sluttid (HH:mm)
  color           String         @default("default")
  completed       Boolean        @default(false)

  // Håller ihop todos som skapats för hela gruppen (logisk gruppering)
  groupIdentifier String?

  recurrence      RecurrenceType @default(NONE)
  interval        Int            @default(1)
  daysOfWeek      String?

  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model PostIt {
  id        String   @id @default(cuid())
  content   String
  color     String   @default("#fef08a") // Klassisk post-it gul
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}