// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// prisma/schema.prisma

model Group {
  id        String   @id @default(cuid())
  name      String
  users     User[]
  createdAt DateTime @default(now())
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  name          String
  role          Role      @default(USER)
  groupId   String?
  group     Group?    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  todos         Todo[]
  postIts       PostIt[]
  createdAt     DateTime  @default(now())
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  ADMIN
  GUEST
}

enum RecurrenceType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

model Todo {
  id          String         @id @default(cuid())
  title       String
  date        String         // Startdatum
  time        String?
  color       String         @default("default")
  completed   Boolean        @default(false)

  // Återkommande todo-logik
  recurrence  RecurrenceType @default(NONE)
  interval    Int            @default(1)    // t.ex. var 2:a vecka (2)
  daysOfWeek  String?        // Sparas som "1,3,5" (mån, ons, fre)

  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}


model PostIt {
  id        String   @id @default(cuid())
  content   String
  color     String   @default("#fef08a") // Klassisk post-it gul
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}